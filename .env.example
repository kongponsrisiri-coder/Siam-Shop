# SiamShop backend environment variables
# Copy to .env for local dev (never commit .env). On Railway, set these in the service Variables tab.

# PostgreSQL — auto-set by Railway when you add a Postgres plugin
DATABASE_URL=postgresql://user:pass@host:5432/railway

# HMAC secret for admin auth tokens. Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# Admin login password (the owner password used to obtain an admin token).
# For the scaffold this is a single shared password; multi-user admin comes later.
ADMIN_PASSWORD=changeme

# Brevo transactional email (same key as SiamEPOS — ask Korakot)
BREVO_API_KEY=
# From-address shown on customer order emails
FROM_EMAIL=orders@siamshop.co.uk
FROM_NAME=SiamShop

# Stripe — LIVE keys from day one (this is a real shop). Use sk_test_/pk_test_ for local dev.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Set after creating the Railway webhook endpoint in the Stripe Dashboard
STRIPE_WEBHOOK_SECRET=

# Anthropic API — for AI product features (descriptions, tagging, search)
ANTHROPIC_API_KEY=

# Netlify frontend URL — used for CORS + Stripe Checkout redirect URLs
FRONTEND_URL=http://localhost:5173

# Default shop slug seeded on first boot (single-tenant for the demo)
DEFAULT_SHOP_SLUG=demo
DEFAULT_SHOP_NAME=SiamShop Demo

# Port (Railway sets this automatically)
PORT=3002
